# Copy to .env and fill in values
INFLUX_PASSWORD=changeme
INFLUX_TOKEN=changeme-long-random-token
GRAFANA_PASSWORD=zymoscope

# Kasa smart plug IPs (optional — leave empty to use GPIO relays instead)
# Set these to control a heater/cooler via a TP-Link Kasa plug (e.g. KP115)
# instead of wiring mains through the relay module.
#
# The matching *_ALIAS vars are an optional safety net: if the plug's IP
# changes (DHCP lease shuffle, plug reboot), the dashboard broadcasts on
# the LAN and rebinds to the device whose Kasa alias matches. Recommended
# if you can't pin a static DHCP lease for the plug.
KASA_HEATER_HOST=
KASA_HEATER_ALIAS=
KASA_COOLER_HOST=
KASA_COOLER_ALIAS=
