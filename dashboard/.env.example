# Copy to .env and fill in values
INFLUX_PASSWORD=changeme
INFLUX_TOKEN=changeme-long-random-token
GRAFANA_PASSWORD=zymoscope

# Kasa smart plug IPs (optional — leave empty to use GPIO relays instead)
# Set these to control a heater/cooler via a TP-Link Kasa plug (e.g. KP115)
# instead of wiring mains through the relay module.
KASA_HEATER_HOST=
KASA_COOLER_HOST=
